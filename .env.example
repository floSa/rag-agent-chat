# ============================================================
# rag-agent-chat — Configuration
# Copier en .env et remplir les valeurs manquantes
# ============================================================

# --- Stores (réseau rag_network du projet rag-ingestion-pipeline) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_documents

NEBULA_HOST=graphd
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=rag_space

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=             # même valeur que rag-ingestion-pipeline
MINIO_BUCKET=documents
MINIO_SECURE=false

# --- LLM local (Ollama) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:e4b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_THINKING=false    # Gemma 4 raisonne par défaut : prohibitif en CPU, activer si GPU

# --- Retrieval ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2   # DOIT correspondre au modèle d'ingestion
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RETRIEVAL_TOP_K=20
RERANK_TOP_K=10
MAX_SEARCH_ITERATIONS=3
CONTEXT_DEPTH=1                          # profondeur de remontée dans le graphe

# --- Prompts ---
PROMPTS_DIR=/app/prompts

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
